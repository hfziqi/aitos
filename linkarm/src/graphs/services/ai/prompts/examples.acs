graph examples {
  meta: { description: "Code examples prompt", type: "prompt", category: "ai", author: "AITOS Team" }

  let prompt = set(key: "_promptExamples", value: "## Example 1: Simple Counter (2 buttons)\n\n**Main graph (counter.acs):**\n```\ngraph counter {\n  meta: { description: \"Simple counter\", type: \"app\", icon: \"🔢\" }\n  \n  let getContainer = get(key: \"growthContainerId\")\n  let initCount = set(key: \"counterValue\", value: 0)\n  \n  let createDisplay = createElement(tag: \"div\", id: \"counterDisplay\")\n  let setDisplayStyles = setStyles(id: \"counterDisplay\", styles: { fontSize: \"48px\", textAlign: \"center\", margin: \"20px\" })\n  let setDisplayText = setTextContent(id: \"counterDisplay\", text: \"0\")\n  let appendDisplay = appendChild(parentId: \"\\{{getContainer}}\", childId: \"counterDisplay\")\n  \n  let createBtnContainer = createElement(tag: \"div\", id: \"counterBtns\")\n  let setBtnContainerStyles = setStyles(id: \"counterBtns\", styles: { display: \"flex\", justifyContent: \"center\", gap: \"10px\" })\n  let appendBtnContainer = appendChild(parentId: \"\\{{getContainer}}\", childId: \"counterBtns\")\n  \n  let createDecBtn = createElement(tag: \"button\", id: \"counterDec\")\n  let setDecText = setTextContent(id: \"counterDec\", text: \"-\")\n  let appendDecBtn = appendChild(parentId: \"counterBtns\", childId: \"counterDec\")\n  \n  let createIncBtn = createElement(tag: \"button\", id: \"counterInc\")\n  let setIncText = setTextContent(id: \"counterInc\", text: \"+\")\n  let appendIncBtn = appendChild(parentId: \"counterBtns\", childId: \"counterInc\")\n}\n```\n\n**Event handler (growths/counter/handle-click.acs):**\n```\ngraph handle-click {\n  let getTargetId = get(key: \"clickTargetId\")\n  let getCount = get(key: \"counterValue\")\n  \n  let isInc = eq(a: \"\\{{getTargetId}}\", b: \"counterInc\")\n  let handleInc = if isInc {\n    let newCount = add(a: \"\\{{getCount}}\", b: 1)\n    let saveCount = set(key: \"counterValue\", value: \"\\{{newCount}}\")\n    let updateDisplay = setTextContent(id: \"counterDisplay\", text: \"\\{{newCount}}\")\n  }\n  \n  let isDec = eq(a: \"\\{{getTargetId}}\", b: \"counterDec\")\n  let handleDec = if isDec {\n    let newCount = sub(a: \"\\{{getCount}}\", b: 1)\n    let saveCount = set(key: \"counterValue\", value: \"\\{{newCount}}\")\n    let updateDisplay = setTextContent(id: \"counterDisplay\", text: \"\\{{newCount}}\")\n  }\n}\n```\n\n---\n\n## Example 2: Calculator (decomposed - 15+ buttons)\n\nThis demonstrates the decomposition strategy for complex apps.\n\n**Main graph (calculator.acs):**\n```\ngraph calculator {\n  meta: { description: \"Calculator\", type: \"app\", icon: \"🧮\" }\n  \n  let getContainer = get(key: \"growthContainerId\")\n  let initDisplay = set(key: \"calcDisplay\", value: \"0\")\n  let initPrev = set(key: \"calcPrev\", value: \"\")\n  let initOp = set(key: \"calcOp\", value: \"\")\n  let initClearNext = set(key: \"calcClearNext\", value: false)\n  \n  let createScreen = createElement(tag: \"div\", id: \"calcScreen\")\n  let setScreenStyles = setStyles(id: \"calcScreen\", styles: { fontSize: \"32px\", textAlign: \"right\", padding: \"10px\", background: \"#222\", color: \"#fff\", borderRadius: \"4px\", margin: \"10px\", minHeight: \"40px\" })\n  let setScreenText = setTextContent(id: \"calcScreen\", text: \"0\")\n  let appendScreen = appendChild(parentId: \"\\{{getContainer}}\", childId: \"calcScreen\")\n  \n  let createGrid = createElement(tag: \"div\", id: \"calcGrid\")\n  let setGridStyles = setStyles(id: \"calcGrid\", styles: { display: \"grid\", gridTemplateColumns: \"repeat(4, 1fr)\", gap: \"5px\", padding: \"10px\" })\n  let appendGrid = appendChild(parentId: \"\\{{getContainer}}\", childId: \"calcGrid\")\n  \n  let createBtn7 = createElement(tag: \"button\", id: \"calc-btn-7\")\n  let setBtn7 = setTextContent(id: \"calc-btn-7\", text: \"7\")\n  let appendBtn7 = appendChild(parentId: \"calcGrid\", childId: \"calc-btn-7\")\n  \n  let createBtn8 = createElement(tag: \"button\", id: \"calc-btn-8\")\n  let setBtn8 = setTextContent(id: \"calc-btn-8\", text: \"8\")\n  let appendBtn8 = appendChild(parentId: \"calcGrid\", childId: \"calc-btn-8\")\n  \n  let createBtn9 = createElement(tag: \"button\", id: \"calc-btn-9\")\n  let setBtn9 = setTextContent(id: \"calc-btn-9\", text: \"9\")\n  let appendBtn9 = appendChild(parentId: \"calcGrid\", childId: \"calc-btn-9\")\n  \n  let createBtnDiv = createElement(tag: \"button\", id: \"calc-btn-div\")\n  let setBtnDiv = setTextContent(id: \"calc-btn-div\", text: \"÷\")\n  let appendBtnDiv = appendChild(parentId: \"calcGrid\", childId: \"calc-btn-div\")\n  \n  let createBtn4 = createElement(tag: \"button\", id: \"calc-btn-4\")\n  let setBtn4 = setTextContent(id: \"calc-btn-4\", text: \"4\")\n  let appendBtn4 = appendChild(parentId: \"calcGrid\", childId: \"calc-btn-4\")\n  \n  let createBtn5 = createElement(tag: \"button\", id: \"calc-btn-5\")\n  let setBtn5 = setTextContent(id: \"calc-btn-5\", text: \"5\")\n  let appendBtn5 = appendChild(parentId: \"calcGrid\", childId: \"calc-btn-5\")\n  \n  let createBtn6 = createElement(tag: \"button\", id: \"calc-btn-6\")\n  let setBtn6 = setTextContent(id: \"calc-btn-6\", text: \"6\")\n  let appendBtn6 = appendChild(parentId: \"calcGrid\", childId: \"calc-btn-6\")\n  \n  let createBtnMul = createElement(tag: \"button\", id: \"calc-btn-mul\")\n  let setBtnMul = setTextContent(id: \"calc-btn-mul\", text: \"×\")\n  let appendBtnMul = appendChild(parentId: \"calcGrid\", childId: \"calc-btn-mul\")\n  \n  let createBtn1 = createElement(tag: \"button\", id: \"calc-btn-1\")\n  let setBtn1 = setTextContent(id: \"calc-btn-1\", text: \"1\")\n  let appendBtn1 = appendChild(parentId: \"calcGrid\", childId: \"calc-btn-1\")\n  \n  let createBtn2 = createElement(tag: \"button\", id: \"calc-btn-2\")\n  let setBtn2 = setTextContent(id: \"calc-btn-2\", text: \"2\")\n  let appendBtn2 = appendChild(parentId: \"calcGrid\", childId: \"calc-btn-2\")\n  \n  let createBtn3 = createElement(tag: \"button\", id: \"calc-btn-3\")\n  let setBtn3 = setTextContent(id: \"calc-btn-3\", text: \"3\")\n  let appendBtn3 = appendChild(parentId: \"calcGrid\", childId: \"calc-btn-3\")\n  \n  let createBtnSub = createElement(tag: \"button\", id: \"calc-btn-sub\")\n  let setBtnSub = setTextContent(id: \"calc-btn-sub\", text: \"-\")\n  let appendBtnSub = appendChild(parentId: \"calcGrid\", childId: \"calc-btn-sub\")\n  \n  let createBtn0 = createElement(tag: \"button\", id: \"calc-btn-0\")\n  let setBtn0 = setTextContent(id: \"calc-btn-0\", text: \"0\")\n  let appendBtn0 = appendChild(parentId: \"calcGrid\", childId: \"calc-btn-0\")\n  \n  let createBtnDot = createElement(tag: \"button\", id: \"calc-btn-dot\")\n  let setBtnDot = setTextContent(id: \"calc-btn-dot\", text: \".\")\n  let appendBtnDot = appendChild(parentId: \"calcGrid\", childId: \"calc-btn-dot\")\n  \n  let createBtnEq = createElement(tag: \"button\", id: \"calc-btn-eq\")\n  let setBtnEq = setTextContent(id: \"calc-btn-eq\", text: \"=\")\n  let appendBtnEq = appendChild(parentId: \"calcGrid\", childId: \"calc-btn-eq\")\n  \n  let createBtnAdd = createElement(tag: \"button\", id: \"calc-btn-add\")\n  let setBtnAdd = setTextContent(id: \"calc-btn-add\", text: \"+\")\n  let appendBtnAdd = appendChild(parentId: \"calcGrid\", childId: \"calc-btn-add\")\n  \n  let createBtnC = createElement(tag: \"button\", id: \"calc-btn-c\")\n  let setBtnC = setTextContent(id: \"calc-btn-c\", text: \"C\")\n  let appendBtnC = appendChild(parentId: \"calcGrid\", childId: \"calc-btn-c\")\n}\n```\n\n**Router (growths/calculator/handle-click.acs):**\n```\ngraph handle-click {\n  let targetId = get(key: \"clickTargetId\")\n  let isDigit = startsWith(text: \"\\{{targetId}}\", prefix: \"calc-btn-\")\n  let isOp = or(a: eq(a: \"\\{{targetId}}\", b: \"calc-btn-add\"), b: or(a: eq(a: \"\\{{targetId}}\", b: \"calc-btn-sub\"), b: or(a: eq(a: \"\\{{targetId}}\", b: \"calc-btn-mul\"), b: eq(a: \"\\{{targetId}}\", b: \"calc-btn-div\"))))\n  let isEquals = eq(a: \"\\{{targetId}}\", b: \"calc-btn-eq\")\n  let isClear = eq(a: \"\\{{targetId}}\", b: \"calc-btn-c\")\n  let isDot = eq(a: \"\\{{targetId}}\", b: \"calc-btn-dot\")\n  let routeDigit = if isDigit {\n    let exec = execFile(file: \"calculator/handle-digit\")\n  }\n  let routeOp = if isOp {\n    let exec = execFile(file: \"calculator/handle-operator\")\n  }\n  let routeEquals = if isEquals {\n    let exec = execFile(file: \"calculator/handle-equals\")\n  }\n  let routeClear = if isClear {\n    let exec = execFile(file: \"calculator/handle-clear\")\n  }\n  let routeDot = if isDot {\n    let exec = execFile(file: \"calculator/handle-dot\")\n  }\n}\n```\n\n**Sub-handler: handle-digit (growths/calculator/handle-digit.acs):**\n```\ngraph handle-digit {\n  let targetId = get(key: \"clickTargetId\")\n  let current = get(key: \"calcDisplay\")\n  let clearNext = get(key: \"calcClearNext\")\n  let digit = slice(array: \"\\{{targetId}}\", start: 9)\n  let shouldReplace = or(a: eq(a: \"\\{{current}}\", b: \"0\"), b: \"\\{{clearNext}}\")\n  let newDisplay = if shouldReplace {\n    let saveDigit = set(key: \"calcDisplay\", value: \"\\{{digit}}\")\n    let clearFlag = set(key: \"calcClearNext\", value: false)\n  } else {\n    let combined = concat(a: \"\\{{current}}\", b: \"\\{{digit}}\")\n    let saveCombined = set(key: \"calcDisplay\", value: \"\\{{combined}}\")\n  }\n  let getFinal = get(key: \"calcDisplay\")\n  let updateScreen = setTextContent(id: \"calcScreen\", text: \"\\{{getFinal}}\")\n}\n```\n\n**Sub-handler: handle-operator (growths/calculator/handle-operator.acs):**\n```\ngraph handle-operator {\n  let targetId = get(key: \"clickTargetId\")\n  let current = get(key: \"calcDisplay\")\n  let savePrev = set(key: \"calcPrev\", value: \"\\{{current}}\")\n  let isAdd = eq(a: \"\\{{targetId}}\", b: \"calc-btn-add\")\n  let opAdd = if isAdd {\n    let saveOp = set(key: \"calcOp\", value: \"+\")\n  }\n  let isSub = eq(a: \"\\{{targetId}}\", b: \"calc-btn-sub\")\n  let opSub = if isSub {\n    let saveOp = set(key: \"calcOp\", value: \"-\")\n  }\n  let isMul = eq(a: \"\\{{targetId}}\", b: \"calc-btn-mul\")\n  let opMul = if isMul {\n    let saveOp = set(key: \"calcOp\", value: \"*\")\n  }\n  let isDiv = eq(a: \"\\{{targetId}}\", b: \"calc-btn-div\")\n  let opDiv = if isDiv {\n    let saveOp = set(key: \"calcOp\", value: \"/\")\n  }\n  let setClear = set(key: \"calcClearNext\", value: true)\n}\n```\n\n**Sub-handler: handle-equals (growths/calculator/handle-equals.acs):**\n```\ngraph handle-equals {\n  let current = get(key: \"calcDisplay\")\n  let prev = get(key: \"calcPrev\")\n  let op = get(key: \"calcOp\")\n  let numCurrent = toNum(value: \"\\{{current}}\")\n  let numPrev = toNum(value: \"\\{{prev}}\")\n  let isAdd = eq(a: \"\\{{op}}\", b: \"+\")\n  let calcAdd = if isAdd {\n    let result = add(a: \"\\{{numPrev}}\", b: \"\\{{numCurrent}}\")\n    let saveResult = set(key: \"calcDisplay\", value: \"\\{{result}}\")\n  }\n  let isSub = eq(a: \"\\{{op}}\", b: \"-\")\n  let calcSub = if isSub {\n    let result = sub(a: \"\\{{numPrev}}\", b: \"\\{{numCurrent}}\")\n    let saveResult = set(key: \"calcDisplay\", value: \"\\{{result}}\")\n  }\n  let isMul = eq(a: \"\\{{op}}\", b: \"*\")\n  let calcMul = if isMul {\n    let result = mul(a: \"\\{{numPrev}}\", b: \"\\{{numCurrent}}\")\n    let saveResult = set(key: \"calcDisplay\", value: \"\\{{result}}\")\n  }\n  let isDiv = eq(a: \"\\{{op}}\", b: \"/\")\n  let calcDiv = if isDiv {\n    let result = div(a: \"\\{{numPrev}}\", b: \"\\{{numCurrent}}\")\n    let saveResult = set(key: \"calcDisplay\", value: \"\\{{result}}\")\n  }\n  let getFinal = get(key: \"calcDisplay\")\n  let updateScreen = setTextContent(id: \"calcScreen\", text: \"\\{{getFinal}}\")\n  let clearOp = set(key: \"calcOp\", value: \"\")\n  let clearPrev = set(key: \"calcPrev\", value: \"\")\n  let setClearNext = set(key: \"calcClearNext\", value: true)\n}\n```\n\n**Sub-handler: handle-clear (growths/calculator/handle-clear.acs):**\n```\ngraph handle-clear {\n  let clearDisplay = set(key: \"calcDisplay\", value: \"0\")\n  let clearPrev = set(key: \"calcPrev\", value: \"\")\n  let clearOp = set(key: \"calcOp\", value: \"\")\n  let clearFlag = set(key: \"calcClearNext\", value: false)\n  let updateScreen = setTextContent(id: \"calcScreen\", text: \"0\")\n}\n```\n\n**Sub-handler: handle-dot (growths/calculator/handle-dot.acs):**\n```\ngraph handle-dot {\n  let current = get(key: \"calcDisplay\")\n  let hasDot = contains(text: \"\\{{current}}\", search: \".\")\n  let addDot = if not(value: \"\\{{hasDot}}\") {\n    let newDisplay = concat(a: \"\\{{current}}\", b: \".\")\n    let save = set(key: \"calcDisplay\", value: \"\\{{newDisplay}}\")\n    let updateScreen = setTextContent(id: \"calcScreen\", text: \"\\{{newDisplay}}\")\n  }\n}\n```\n\n**Key takeaways from this example:**\n1. The router dispatches by button type, not individual button\n2. Each sub-handler is simple (2-4 branches max)\n3. State is shared via store keys (calcDisplay, calcPrev, calcOp, calcClearNext)\n4. `toNum()` converts string to number for arithmetic\n5. `contains()` checks if display already has a decimal point\n6. `startsWith()` in router identifies digit buttons by prefix pattern\n7. `not()` is used as inline condition: `if not(value: \\{{hasDot}})`")
}

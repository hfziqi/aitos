graph ai-tools-config {
  meta: { description: "AI tools configuration data", type: "data", category: "ai", author: "AITOS Team" }

  let setTools = set(key: "aiToolsConfig", value: [{ type: "function", function: { name: "getSkillSet", description: "ONLY call when user explicitly asks to create/modify graphs. Get all available atoms, graph format, and validation rules. Call this FIRST before creating any graph to understand available building blocks.", parameters: { type: "object", properties: {}, required: [] } } }, { type: "function", function: { name: "save-growth", description: "ONLY call when user explicitly asks to create/modify graphs. Create and register a new growth graph. This is the ONLY way to create new capabilities. Provide name, ACS source code, type, icon, and description.", parameters: { type: "object", properties: { name: { type: "string", description: "Growth name, use / for subgraphs like math/calc" }, acs: { type: "string", description: "ACS source code of the graph" }, type: { type: "string", description: "Growth type: app or tool", enum: ["app", "tool"] }, icon: { type: "string", description: "Growth icon emoji" }, description: { type: "string", description: "Growth description" } }, required: ["name", "acs"] } } }, { type: "function", function: { name: "callGrowthTool", description: "ONLY call when user explicitly asks to use a previously created tool. Execute a registered tool growth by name. Pass the tool name and its arguments.", parameters: { type: "object", properties: { name: { type: "string", description: "Name of the tool growth to execute" }, args: { type: "object", description: "Arguments to pass to the tool" } }, required: ["name", "args"] } } }, { type: "function", function: { name: "get-growth-log", description: "ONLY call when user explicitly asks to create/modify graphs. Get the creation log for a specific growth. Shows all past attempts with errors and successes. Use this BEFORE creating a growth to learn from past mistakes and avoid repeating errors.", parameters: { type: "object", properties: { name: { type: "string", description: "Growth name to look up (e.g. calculator)" } }, required: ["name"] } } }, { type: "function", function: { name: "list-growths", description: "ONLY call when user explicitly asks to create/modify graphs. List all growths (user-created graphs). Returns an array of { name, path, type, icon, description }. Call this to see what graphs have been created.", parameters: { type: "object", properties: {}, required: [] } } }, { type: "function", function: { name: "get-growth-code", description: "ONLY call when user explicitly asks to create/modify graphs. Get the ACS source code for a specific growth. Use this to inspect or debug a growth's implementation.", parameters: { type: "object", properties: { name: { type: "string", description: "Growth name to look up (e.g. calculator)" } }, required: ["name"] } } }, { type: "function", function: { name: "analyze-telemetry", description: "ONLY call when user explicitly asks to create/modify graphs. Analyze telemetry data from local storage. Returns summary (total calls, error rate, avg duration), error hotspots, and all atom stats. Use this to identify performance bottlenecks and optimization opportunities.", parameters: { type: "object", properties: {}, required: [] } } }, { type: "function", function: { name: "getTraceLog", description: "ONLY call when user explicitly asks to create/modify graphs. Query execution trace log with filters. Each entry records an atom execution with traceChainId (grouping atoms from the same user operation), graph name, atom name, input, duration, and success status. Use traceChainId to get a complete user operation flow (e.g. from click to render). Use graph/atom/success filters to narrow down. Results are limited to 100 by default.", parameters: { type: "object", properties: { traceChainId: { type: "string", description: "Get complete flow for a specific user operation" }, graph: { type: "string", description: "Filter by graph name (e.g. chat-loop, calculator)" }, atom: { type: "string", description: "Filter by atom name (e.g. httpStreamRequest)" }, success: { type: "boolean", description: "Filter by success (true) or failure (false)" }, limit: { type: "number", description: "Max entries to return (default 100)" } }, required: [] } } }, { type: "function", function: { name: "flushTelemetry", description: "ONLY call when user explicitly asks to create/modify graphs. Save current telemetry data as a historical snapshot for future trend analysis.", parameters: { type: "object", properties: {}, required: [] } } }])
}

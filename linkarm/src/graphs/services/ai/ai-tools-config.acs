graph ai-tools-config {
  meta: { description: "AI tools configuration data", type: "data", category: "ai", author: "AITOS Team" }

  let setTools = set(key: "aiToolsConfig", value: [{ type: "function", function: { name: "getSkillSet", description: "Get all available atoms, graph format, and validation rules. Call this FIRST before creating any graph to understand available building blocks.", parameters: { type: "object", properties: {}, required: [] } } }, { type: "function", function: { name: "save-growth", description: "Create and register a new growth graph. This is the ONLY way to create new capabilities. Provide name, ACS source code, type, icon, and description.", parameters: { type: "object", properties: { name: { type: "string", description: "Growth name, use / for subgraphs like math/calc" }, acs: { type: "string", description: "ACS source code of the graph" }, type: { type: "string", description: "Growth type: app or tool", enum: ["app", "tool"] }, icon: { type: "string", description: "Growth icon emoji" }, description: { type: "string", description: "Growth description" } }, required: ["name", "acs"] } } }, { type: "function", function: { name: "get-growth-log", description: "Get the creation log for a specific growth. Shows all past attempts with errors and successes. Use this BEFORE creating a growth to learn from past mistakes and avoid repeating errors.", parameters: { type: "object", properties: { name: { type: "string", description: "Growth name to look up (e.g. calculator)" } }, required: ["name"] } } }, { type: "function", function: { name: "analyzeTelemetry", description: "Analyze current telemetry data. Returns summary (total calls, error rate, avg duration), top 10 most-called atoms, error hotspots, and graph usage breakdown. Use this to identify performance bottlenecks and optimization opportunities.", parameters: { type: "object", properties: {}, required: [] } } }, { type: "function", function: { name: "getTelemetryHistory", description: "Get historical telemetry snapshots. Shows trends over time. Use this to understand system evolution and identify long-term optimization patterns.", parameters: { type: "object", properties: {}, required: [] } } }, { type: "function", function: { name: "flushTelemetry", description: "Save current telemetry data as a historical snapshot for future trend analysis.", parameters: { type: "object", properties: {}, required: [] } } }])
}

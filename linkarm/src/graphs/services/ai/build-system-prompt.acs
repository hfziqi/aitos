graph build-system-prompt {
  meta: { description: "Compose system prompt from fragments", type: "service", category: "ai", author: "AITOS Team" }

  let loadBase = execFile(file: "services/ai/prompts/base")
  let loadSystemInfo = execFile(file: "services/ai/prompts/system-info")
  let loadAtomsGuide = execFile(file: "services/ai/prompts/atoms-guide")
  let loadAcsSyntax = execFile(file: "services/ai/prompts/acs-syntax")
  let loadGrowthGuide = execFile(file: "services/ai/prompts/growth-guide")
  let loadExamples = execFile(file: "services/ai/prompts/examples")
  let loadCompileFeedback = execFile(file: "services/ai/prompts/compile-feedback")
  let getBase = get(key: "_promptBase")
  let getSystemInfo = get(key: "_promptSystemInfo")
  let getAtomsGuide = get(key: "_promptAtomsGuide")
  let getAcsSyntax = get(key: "_promptAcsSyntax")
  let getGrowthGuide = get(key: "_promptGrowthGuide")
  let getExamples = get(key: "_promptExamples")
  let getCompileFeedback = get(key: "_promptCompileFeedback")
  let combineFinal = join(array: ["{{getBase}}", "{{getSystemInfo}}", "{{getAtomsGuide}}", "{{getAcsSyntax}}", "{{getGrowthGuide}}", "{{getExamples}}", "{{getCompileFeedback}}"], separator: "\n\n")
}

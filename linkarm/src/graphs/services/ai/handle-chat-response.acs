graph handle-chat-response {
  meta: { description: "Handle chat API response - parse content or tool calls", type: "service", category: "ai", author: "AITOS Team" }

  let getApiResponse = get(key: "apiResponse")
  let getElementId = get(key: "streamElementId")
  let getApiError = getProp(obj: "{{getApiResponse}}", key: "error")
  let checkError = isNil(value: "{{getApiError}}")
  let handleResult = if checkError {
    let getToolCalls = getProp(obj: "{{getApiResponse}}", key: "toolCalls")
    let getToolCallsLen = len(value: "{{getToolCalls}}")
    let checkToolCalls = gt(a: "{{getToolCallsLen}}", b: 0)
    let handleBranch = if checkToolCalls {
      let getContent1 = getProp(obj: "{{getApiResponse}}", key: "content")
      let buildAssistantMsg = merge(a: { role: "assistant", content: "{{getContent1}}" }, b: { tool_calls: "{{getToolCalls}}" })
      let getMsgs1 = get(key: "_apiContext")
      let pushAssistantMsg = push(array: "{{getMsgs1}}", value: "{{buildAssistantMsg}}")
      let handleTools = handleToolCalls(toolCalls: "{{getToolCalls}}")
      let initToolMessages = set(key: "toolMessages", value: "{{pushAssistantMsg}}")
      let appendToolMessagesLoop = forEach toolResult in handleTools  {
        let getToolMessages = get(key: "toolMessages")
        let getToolCallId = getProp(obj: "{{toolResult}}", key: "toolCallId")
        let getToolResultContent = getProp(obj: "{{toolResult}}", key: "result")
        let buildToolMsg = merge(a: { role: "tool", tool_call_id: "{{getToolCallId}}" }, b: { content: "{{getToolResultContent}}" })
        let pushToolMsg = push(array: "{{getToolMessages}}", value: "{{buildToolMsg}}")
        let saveToolMessages = set(key: "toolMessages", value: "{{pushToolMsg}}")
      }
      let getToolMessagesFinal = get(key: "toolMessages")
      let saveMessagesContinue = set(key: "_apiContext", value: "{{getToolMessagesFinal}}")
      let setContinueTrue = set(key: "continueLoop", value: true)
    } else {
      let getContent2 = getProp(obj: "{{getApiResponse}}", key: "content")
      let buildFinalMsg = merge(a: { role: "assistant" }, b: { content: "{{getContent2}}" })
      let getMsgs2 = get(key: "_apiContext")
      let pushAssistantFinal = push(array: "{{getMsgs2}}", value: "{{buildFinalMsg}}")
      let saveMessagesFinal = set(key: "_apiContext", value: "{{pushAssistantFinal}}")
      let saveFinalContent = set(key: "finalContent", value: "{{getContent2}}")
      let setContinueFalse = set(key: "continueLoop", value: false)
    }
  } else {
    let showError = setTextContent(id: "{{getElementId}}", text: "API Error: {{getApiError}}")
    let setContinueFalse = set(key: "continueLoop", value: false)
  }
}

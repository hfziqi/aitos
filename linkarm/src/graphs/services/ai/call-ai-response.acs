graph call-ai-response {
  meta: { description: "Call AI and save response to conversation", type: "action", category: "chat", author: "AITOS Team" }

  let callAI = execFile(file: "services/ai/call-openai")
  let getAIResponse = get(key: "aiResponse")
  let getAIContent = getProp(obj: {{getAIResponse}}, key: "content")
  let buildAIMessage = set(key: "_aiMessageObj", value: { role: "assistant", content: {{getAIContent}}, timestamp: "now" })
  let setNewMessage = set(key: "newMessage", value: {{buildAIMessage}})
  let addAIMessageToConversation = execFile(file: "messages/add-message")
  let appendBubble = execFile(file: "ui/views/chat/append-message")
}

graph switchConversation {
  meta: { description: "Switch conversation - parses conversation ID from clickTargetId", type: "action", category: "conversation", author: "AITOS Team" }

  let getTargetId = get(key: "clickTargetId")
  let findItem = closest(id: "{{getTargetId}}", selector: ".sidebar-item")
  let getConvId = getAttribute(id: "{{findItem}}", name: "data-conv-id")
  let setCurrentConvId = setGlobal(key: "currentConversationId", value: "{{getConvId}}")
  let createCtx = createConversationContext(convId: "{{getConvId}}")
  let setActiveCtx = setGlobal(key: "_activeContext", value: "{{createCtx}}")
  let updateSidebar = executeInContext(contextKey: "_activeContext", graphKey: "__graph_ui/layout/sidebar/update")
  let switchToChat = executeInContext(contextKey: "_activeContext", graphKey: "__graph_ui/views/chat/switch-view")
}
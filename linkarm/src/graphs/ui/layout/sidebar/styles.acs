graph styles {
  meta: { description: "Sidebar appearance styles", type: "styles", category: "sidebar", author: "AITOS Team" }

  let getSideW = get(key: "sideW")
  let setAppearanceStyles = setStyles(id: "sidebarContainer", styles: { width: "{{getSideW}}px", backgroundColor: "#fcfcfc", padding: "8px" })
  let injectScrollbarStyles = injectCSS(id: "sidebarScrollbarHide", css: "#conversationList { scrollbar-width: none; } #conversationList::-webkit-scrollbar { display: none; }")
}
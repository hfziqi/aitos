graph ui/components/model-card/styles {
  meta: { description: "Model card styles", type: "styles", category: "model-card", author: "AITOS Team" }

  let injectStyles = injectCSS(id: "modelCardStyles", css: ".model-card { display: flex; align-items: center; justify-content: space-between; border: 1px solid #e5e5e5; border-radius: 8px; padding: 12px 16px; margin: 8px 0; background: #fff; transition: border-color 0.15s ease, box-shadow 0.15s ease; } .model-card:hover { border-color: #007aff; box-shadow: 0 2px 8px rgba(0, 122, 255, 0.1); } .model-card.selected { border-color: #007aff; background: #f0f7ff; } .model-card > div:first-child { flex: 1; font-size: 14px; color: #333; } .model-card button { margin-left: 8px; }")
}
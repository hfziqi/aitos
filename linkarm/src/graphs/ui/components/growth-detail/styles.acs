graph styles {
  meta: { description: "Growth detail styles", type: "component", category: "growth-detail", author: "AITOS Team" }

  let injectStyles = injectCSS(id: "growthDetailStyles", css: ".growth-detail-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(0, 0, 0, 0.5); display: flex; align-items: center; justify-content: center; z-index: 1000; } .growth-detail { background-color: #fff; border-radius: 12px; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15); width: 400px; display: flex; flex-direction: column; overflow: hidden; } .growth-detail-header { display: flex; align-items: center; justify-content: space-between; padding: 16px 20px; border-bottom: 1px solid #e8e8e8; background-color: #fafafa; } .growth-detail-title { display: flex; align-items: center; gap: 10px; font-size: 16px; font-weight: 600; color: #333; } .growth-detail-icon { font-size: 20px; } .growth-detail-close { background: none; border: none; font-size: 18px; color: #999; padding: 4px 8px; border-radius: 4px; } .growth-detail-body { padding: 20px; } .growth-detail-type-row { display: flex; margin-bottom: 12px; } .growth-detail-type-label { width: 50px; color: #666; font-size: 14px; } .growth-detail-type-value { flex: 1; color: #333; font-size: 14px; } .growth-detail-desc-row { display: flex; } .growth-detail-desc-label { width: 50px; color: #666; font-size: 14px; } .growth-detail-desc-value { flex: 1; color: #333; font-size: 14px; }")
}

graph styles {
  meta: { description: "Message bubble appearance and markdown styles", type: "styles", category: "message-bubble", author: "AITOS Team" }

  let getMsgIndex = get(key: "messageIndex")
  let setAppearanceStyles = setStyles(id: "msg_{{getMsgIndex}}", styles: { maxWidth: "70%", marginBottom: "16px", padding: "8px 16px", borderRadius: "16px", fontSize: "14px", lineHeight: "1.4" })
  let injectMarkdownStyles = injectCSS(id: "markdownStyles", css: ".msg-bubble h1 { font-size: 20px; font-weight: bold; margin: 8px 0 4px 0; } .msg-bubble h2 { font-size: 18px; font-weight: bold; margin: 8px 0 4px 0; } .msg-bubble h3 { font-size: 16px; font-weight: bold; margin: 8px 0 4px 0; } .msg-bubble p { margin: 4px 0; } .msg-bubble ul, .msg-bubble ol { margin: 4px 0; padding-left: 20px; } .msg-bubble li { margin: 2px 0; } .msg-bubble code { background-color: #f0f0f0; padding: 2px 6px; border-radius: 4px; font-size: 13px; font-family: 'Courier New', monospace; } .msg-bubble .md-code-block { background-color: #f5f5f5; border-radius: 8px; overflow: hidden; margin: 8px 0; } .msg-bubble .md-code-header { padding: 6px 12px; font-size: 12px; color: #999; background-color: #e8e8e8; font-family: 'Courier New', monospace; } .msg-bubble .md-code-block code { display: block; padding: 12px; overflow-x: auto; background-color: transparent; } .msg-bubble a { color: #007aff; text-decoration: underline; } .msg-bubble blockquote { border-left: 4px solid #e0e0e0; padding-left: 12px; margin: 8px 0; color: #666; } .msg-bubble hr { border: none; border-top: 1px solid #e0e0e0; margin: 12px 0; } .msg-bubble .md-table { border-collapse: collapse; width: 100%; margin: 8px 0; font-size: 13px; } .msg-bubble .md-table th, .msg-bubble .md-table td { border: 1px solid #ddd; padding: 6px 10px; text-align: left; } .msg-bubble .md-table th { background-color: #f5f5f5; font-weight: bold; } .msg-bubble .md-table tr:nth-child(even) { background-color: #fafafa; } .msg-bubble strong { font-weight: bold; } .msg-bubble em { font-style: italic; } .msg-bubble del { text-decoration: line-through; color: #999; }")
}
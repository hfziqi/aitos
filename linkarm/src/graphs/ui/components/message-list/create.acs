graph ui/components/message-list/create {
  meta: { description: "Create message list container (logic)", type: "component", category: "message-list", author: "AITOS Team" }

  let createMessageList = createElement(tag: "div", id: "messageList")
  let setLayoutStyles = setStyles(id: "messageList", styles: { flex: "1", overflowY: "auto", minHeight: "0", boxSizing: "border-box" })
  let execStyles = execFile(file: "ui/components/message-list/styles")
  let appendMessageList = appendChild(parentId: "mainViewContainer", childId: "messageList")
}
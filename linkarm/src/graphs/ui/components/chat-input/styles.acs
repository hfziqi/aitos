graph styles {
  meta: { description: "Chat input appearance styles", type: "styles", category: "chat-input", author: "AITOS Team" }

  let injectStyles = injectCSS(id: "chatInputStyles", css: ".chat-input-container { display: flex; flex-shrink: 0; width: 100%; padding: 0 16px 12px 16px; box-sizing: border-box; } .chat-input-inner { display: flex; align-items: flex-start; flex: 1; background-color: #fff; border: 1px solid #e0e0e0; border-radius: 20px; padding: 16px; min-height: 60px; position: relative; } .chat-input-box { flex: 1; border: none; outline: none; resize: none; font-size: 14px; line-height: 1.4; min-height: 28px; max-height: 120px; padding: 0 40px 0 8px; background-color: transparent; box-sizing: border-box; overflow: hidden; } .chat-input-send-btn { width: 32px; height: 32px; min-width: 32px; min-height: 32px; border-radius: 50%; background-color: #007aff; color: #fff; border: none; display: flex; align-items: center; justify-content: center; position: absolute; right: 8px; bottom: 14px; }")
}

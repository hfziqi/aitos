graph init-messages {
  meta: { description: "Initialize empty messages file for a conversation", type: "domain", category: "messages", author: "AITOS Team" }

  let getConvId = get(key: "_convId")
  let buildPath = set(key: "_msgPath", value: "chat/messages/{{getConvId}}.json")
  let initFile = writeLocal(key: "{{buildPath}}", value: [])
}
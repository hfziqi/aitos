graph delete-messages {
  meta: { description: "Delete messages file for a conversation", type: "domain", category: "messages", author: "AITOS Team" }

  let getConvId = get(key: "_convId")
  let buildPath = set(key: "_msgPath", value: "chat/messages/{{getConvId}}.json")
  let deleteFile = removeLocal(key: "{{buildPath}}")
}